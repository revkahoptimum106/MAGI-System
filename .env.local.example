# MAGI System — AI API Keys
# Copy this file to .env.local and fill in your API keys

# OpenAI API Key (for MELCHIOR-1)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# Model name (optional, default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Anthropic API Key (for BALTHASAR-2)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model name (optional, default: claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5

# Google AI API Key (for CASPER-3)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
# Model name (optional, default: gemini-2.5-flash)
GOOGLE_MODEL=gemini-2.5-flash
